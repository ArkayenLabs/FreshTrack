<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for Android 11 (API 30) and below.
    Mirrors data_extraction_rules.xml — see that file for the reasoning.

    EncryptedSharedPreferences cannot survive a restore onto another device
    because its master key stays in the source device's keystore.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="freshtrack_prefs.xml" />
    <exclude domain="sharedpref" path="crash_loop_detector.xml" />
</full-backup-content>
