# ==========================================
# ANDROID / KOTLIN PROJECT GITIGNORE (FRESHTRACK)
# ==========================================

# === Gradle ===
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
/local.properties
.gradle_app.setting
gradle-app.setting

# === IntelliJ / Android Studio ===
*.iml
.idea/
!.idea/codeStyles
!.idea/runConfigurations

# === VS Code ===
.vscode/

# === Kotlin / KSP Generated ===
# Ignore generated code, but keep Room schemas
app/build/
app/build/generated/
!app/schemas/**

# === Room / Database Schemas ===
# Keep JSON schema exports for future migrations
!app/schemas/
!app/schemas/**/*.json

# === Native Build Folders ===
.externalNativeBuild/
.cxx/

# === OS / Temporary Files ===
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak

# === Captures / Profiling ===
captures/
outputs/

# === JetBrains Kotlin Cache ===
.kotlin/
out/

# === Firebase ===
# Contains the project's Firebase config and API key. Kept out of the repo by
# choice — a fresh clone or CI build must supply its own copy.
google-services.json

# === Graphify (tool output, not source) ===
graphify-out/
run_graphify.ps1

# === Node (Firestore rules tests only, not the Android build) ===
node_modules/
firestore-debug.log
firebase-debug.log
ui-debug.log
.firebase/

# === Misc ===
*.apk
*.aab
*.keystore
*.jks
keystore.properties
