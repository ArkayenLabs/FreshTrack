rules_version = '2';

// FreshTrack Firestore security rules.
//
// Deny by default: anything not matched below is refused. Every rule assumes a
// hostile client, because the client is a published app that anyone can decompile
// and drive with arbitrary requests.
//
// Shape:
//   /users/{uid}                          profile, entitlement, pantry ids
//   /pantries/{pantryId}                  memberUids is the access-control list
//   /pantries/{pantryId}/products/{id}    the inventory itself
//
// Note on queries: there is no `list` permission on /pantries anywhere below.
// Rules cannot reliably constrain what a collection query returns, so the client
// never queries the collection — it reads its own user document, takes the
// pantry ids, and fetches each pantry by id. That removes a whole class of
// "accidentally readable by everyone" mistakes.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Membership lookup for subcollections. Costs one document read per rule
    // evaluation, which is the price of shared pantries.
    function pantryData(pantryId) {
      return get(/databases/$(database)/documents/pantries/$(pantryId)).data;
    }

    function isMemberOf(pantryId) {
      return isSignedIn() && uid() in pantryData(pantryId).memberUids;
    }

    function isOwnerOf(pantryId) {
      return isSignedIn() && pantryData(pantryId).ownerUid == uid();
    }

    // Entitlement lives on the pantry, not the owner's user document, because
    // the rules already fetch the pantry — checking the owner's profile instead
    // would cost a second billed read on every product write. A Cloud Function
    // sets this when a Play Billing purchase is verified; clients cannot.
    function pantryIsPremium(pantryId) {
      return pantryData(pantryId).get('isPremium', false) == true;
    }

    // Household size. Free pantries are single-user; premium allows a household.
    function memberLimitFor(isPremium) {
      return isPremium ? 6 : 1;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    //
    // `plan` is an entitlement. It must only ever be written by a trusted server
    // (a Cloud Function that has verified a Play Billing purchase). A client that
    // could set its own plan could grant itself premium for free, so both create
    // and update refuse any client-supplied change to it.
    match /users/{userId} {
      allow get: if isSignedIn() && uid() == userId;

      allow create: if isSignedIn()
                    && uid() == userId
                    && !('plan' in request.resource.data);

      allow update: if isSignedIn()
                    && uid() == userId
                    && request.resource.data.get('plan', 'free')
                       == resource.data.get('plan', 'free');

      // A user may delete their own profile as part of deleting their account.
      // Google Play requires an account deletion path, and without Cloud
      // Functions there is no trusted server to do it on their behalf.
      allow delete: if isSignedIn() && uid() == userId;
    }

    // ─── Pantries ───────────────────────────────────────────────────────────
    match /pantries/{pantryId} {

      // Read the pantry document directly from `resource`, rather than calling
      // isMemberOf(), to avoid paying for a second read of the same document.
      allow get: if isSignedIn() && uid() in resource.data.memberUids;

      // A new pantry must be created owned by, and containing only, its creator,
      // and never pre-flagged as premium. Without this a client could create a
      // pantry that already lists someone else as a member, or one that has
      // granted itself a paid entitlement.
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == uid()
                    && request.resource.data.memberUids == [uid()]
                    && request.resource.data.get('isPremium', false) == false;

      // Only the owner changes membership. Ownership and the premium flag are
      // both immutable from a client — otherwise a member could promote
      // themselves and lock the owner out, or anyone could unlock a family plan.
      allow update: if isOwnerOf(pantryId)
                    && request.resource.data.ownerUid == resource.data.ownerUid
                    && request.resource.data.get('isPremium', false)
                       == resource.data.get('isPremium', false)
                    && uid() in request.resource.data.memberUids
                    && request.resource.data.memberUids.size()
                       <= memberLimitFor(pantryIsPremium(pantryId));

      allow delete: if isOwnerOf(pantryId);

      // ─── Products ─────────────────────────────────────────────────────────
      match /products/{productId} {

        // Reads stay open to members regardless of plan. If a subscription
        // lapses the user can still read back and export what they already
        // uploaded — their data is not held hostage. Only further backup stops.
        allow get: if isMemberOf(pantryId);
        allow list: if isMemberOf(pantryId);

        // Writing to the cloud is the premium feature. Free accounts are fully
        // functional offline; nothing is capped locally.
        //
        // updatedAt drives last-write-wins, so a write without a usable
        // timestamp is rejected rather than silently winning or losing.
        allow create, update: if isMemberOf(pantryId)
                              && pantryIsPremium(pantryId)
                              && request.resource.data.updatedAt is number;

        // Everyday deletion is soft: the client sets isDeleted so the removal
        // can propagate to other devices. A hard delete would vanish without
        // ever reaching them.
        //
        // The owner is nonetheless allowed to hard-delete, because account
        // deletion has to actually erase the data. Firestore does not cascade
        // into subcollections, so deleting the pantry alone would leave every
        // product orphaned in the database forever — which is precisely the
        // retention failure the deletion requirement exists to prevent. With no
        // Cloud Function available, the client must do it.
        //
        // Members cannot hard-delete: for them, soft delete remains the only
        // route, so a shared pantry cannot be quietly emptied.
        allow delete: if isOwnerOf(pantryId);
      }
    }
  }
}
